# Flowly test-server env — used by docker-compose.yml.
#
#   cp .env.server.example .env.server      # then edit the values below
#   docker compose --env-file .env.server up -d --build
#
# .env.server is git-ignored (real secrets). This .example is the committed
# template. See SERVER-TEST.md for the full runbook.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# The server's public IP or hostname — NO scheme, NO port, NO trailing slash.
# This is baked into API_BASE_URL / WEB_BASE_URL / the tracker URL and the web
# bundle. It MUST match exactly how you reach the box in the browser, or CORS
# and the live WebSocket will reject every request. Example: 203.0.113.10
SERVER_IP=CHANGE_ME

# Keep "local" for a feature-test box with no email provider: signup / verify /
# password-reset responses then include the one-time `dev_code` on-screen, so you
# can complete those flows without real email. Set to "production" ONLY if you
# also set a real EMAIL_API_KEY below (otherwise codes go only to the logs).
ENVIRONMENT=local

# Secrets — generate long random values, e.g.  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
VISITOR_SALT_SECRET=CHANGE_ME_openssl_rand_hex_32
POSTGRES_PASSWORD=CHANGE_ME
CLICKHOUSE_PASSWORD=CHANGE_ME

# ── OPTIONAL integrations (blank = that feature degrades gracefully) ─────────

# Stripe metered billing. Blank = billing inert (checkout/paywall untestable).
# A public HTTPS URL is required for real webhooks, so leave blank on an IP/HTTP
# box (see SERVER-TEST.md "What you can't test over plain HTTP").
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_METERED=
STRIPE_METER_EVENT=pageviews

# Google / GitHub sign-in + Search Console. Need HTTPS redirect URIs, so these
# won't complete over plain IP/HTTP — leave blank for the first pass.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Transactional email (Resend). Blank = dev-stub: codes/alerts are logged only.
EMAIL_API_KEY=
EMAIL_FROM=Flowly <noreply@flowly.local>
CONTACT_EMAIL=

# Support-chatbot AI fallback. Blank = bot answers the hardcoded FAQ only.
ANTHROPIC_API_KEY=

# Landing-page live-demo share token. Blank = the hero shows labeled sample data.
NEXT_PUBLIC_DEMO_SHARE_TOKEN=

# Uptime pinger master switch (off by default; nothing pings sites until true).
UPTIME_ENABLED=false
