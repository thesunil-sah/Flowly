# Flowly environment — copy this file to `.env` at the repo ROOT and fill real values.
# `.env` is git-ignored. Only the App group is read in Phase 0; the rest are
# scaffolded now with obviously-fake placeholders and consumed in later phases.

# --- App (used in Phase 0) ---
ENVIRONMENT=local
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# --- Auth (later) ---
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# --- Postgres (later) ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/flowly

# --- ClickHouse (later) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=flowly

# --- Redis (later) ---
REDIS_URL=redis://localhost:6379/0

# --- Stripe (later) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# --- Email (later) ---
EMAIL_API_KEY=xxx
EMAIL_FROM=Flowly <noreply@flowly.local>

# --- Social OAuth (optional; a provider is enabled only when both are set) ---
# Google  redirect URI: {API_BASE_URL}/auth/oauth/google/callback
# GitHub  redirect URI: {API_BASE_URL}/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Tracking / Ingestion ---
# VISITOR_SALT_SECRET is the pepper for the cookieless visitor hash — set a
# long random value in production (never commit the real one).
VISITOR_SALT_SECRET=change-me
TRACKER_SCRIPT_URL=http://localhost:8000/script.js
# Path to a MaxMind GeoLite2-City .mmdb (blank -> geo enrichment fails open).
GEOIP_DB_PATH=
# Approximate cap for the Redis ingest stream (XADD MAXLEN ~).
STREAM_MAXLEN=1000000
# Per-(site_id, IP) /collect rate limit (abuse backstop).
COLLECT_RATE_LIMIT=600
COLLECT_RATE_WINDOW=60
