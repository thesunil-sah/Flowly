# Flowly environment — copy this file to `.env` at the repo ROOT and fill real values.
# `.env` is git-ignored. Only the App group is read in Phase 0; the rest are
# scaffolded now with obviously-fake placeholders and consumed in later phases.

# --- App (used in Phase 0) ---
ENVIRONMENT=local
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# --- Auth (later) ---
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# --- Postgres (later) ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/flowly

# --- ClickHouse (later) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=flowly

# --- Redis (later) ---
REDIS_URL=redis://localhost:6379/0

# --- Stripe (Phase 7) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe-dashboard-created price ids (monthly + annual per tier).
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_BUSINESS_ANNUAL=price_xxx

# --- Uptime monitoring (Phase 12) ---
# Off by default: nothing pings customer sites until an operator enables it.
UPTIME_ENABLED=false
UPTIME_CHECK_TIMEOUT=8.0
# Consecutive failed checks before an incident opens + the owner is alerted.
UPTIME_FAIL_THRESHOLD=2
# Max redirect hops followed (each hop re-validated by the SSRF guard).
UPTIME_MAX_REDIRECTS=3

# --- Email (later) ---
# Resend API key. With it blank, all email is logged (dev stub) instead of sent;
# set it and mail is delivered — even locally. For Resend test mode (no verified
# domain) use EMAIL_FROM=onboarding@resend.dev and send only to your Resend
# account's own address.
EMAIL_API_KEY=xxx
EMAIL_FROM=Flowly <noreply@flowly.local>
# Inbox that public contact-form submissions go to. Blank -> falls back to EMAIL_FROM.
CONTACT_EMAIL=

# --- Assistant / support chatbot (Phase F7) ---
# Anthropic API key for the chatbot's AI fallback (small/cheap model). Blank ->
# the bot answers the hardcoded FAQ intents and points everything else to contact.
ANTHROPIC_API_KEY=

# --- Social OAuth (optional; a provider is enabled only when both are set) ---
# Google  redirect URI: {API_BASE_URL}/auth/oauth/google/callback
# GitHub  redirect URI: {API_BASE_URL}/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Web (Next.js) ---
# NEXT_PUBLIC_* vars are inlined into the browser bundle at BUILD time, and
# Next.js reads env files from apps/web/ (not the repo root) — put real dev
# values in apps/web/.env.local (git-ignored) or the build environment.
NEXT_PUBLIC_API_URL=http://localhost:8000
# A Phase 8 share token for Flowly's own site, powering the landing page's
# live demo hero. Share tokens are public by design. Blank -> the landing
# page shows labeled sample data instead.
NEXT_PUBLIC_DEMO_SHARE_TOKEN=

# --- Tracking / Ingestion ---
# VISITOR_SALT_SECRET is the pepper for the cookieless visitor hash — set a
# long random value in production (never commit the real one).
VISITOR_SALT_SECRET=change-me
TRACKER_SCRIPT_URL=http://localhost:8000/script.js
# Path to a MaxMind GeoLite2-City .mmdb (blank -> geo enrichment fails open).
GEOIP_DB_PATH=
# Approximate cap for the Redis ingest stream (XADD MAXLEN ~).
STREAM_MAXLEN=1000000
# Per-(site_id, IP) /collect rate limit (abuse backstop).
COLLECT_RATE_LIMIT=600
COLLECT_RATE_WINDOW=60
